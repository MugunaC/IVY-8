{
  "name": "ivy",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:client": "vite --host 0.0.0.0 --port 5173",
    "dev:client:remote": "vite --host 0.0.0.0 --port 5173 --mode remote",
    "dev:server": "npm run build:ws && node dist-server/server/index.js",
    "dev:api": "npm run build:ws && node dist-server/server/api.js",
    "dev:ws": "npm run build:ws && node dist-server/server/ws.js",
    "dev:gateway": "npm run build:ws && node dist-server/server/gateway.js",
    "dev:gateway:proxy": "set GATEWAY_PROXY_UI=1&& npm run dev:gateway",
    "dev:remote:one": "powershell -ExecutionPolicy Bypass -File .\\scripts\\remote-one.ps1",
    "dev:remote:one:termux": "bash ./scripts/remote-one.sh",
    "build": "vite build",
    "build:ws": "tsc -p tsconfig.server.json",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts,.tsx",
    "auth:reset": "node scripts/reset-password.mjs"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "1.1.4",
    "@radix-ui/react-dialog": "1.1.6",
    "@radix-ui/react-label": "2.1.2",
    "@radix-ui/react-select": "2.1.6",
    "@radix-ui/react-slot": "1.1.2",
    "@radix-ui/react-tabs": "1.1.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "0.487.0",
    "maplibre-gl": "^5.18.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router": "^7.13.0",
    "sonner": "2.0.3",
    "tailwind-merge": "3.2.0",
    "tw-animate-css": "1.3.8",
    "ws": "^8.19.0",
    "better-sqlite3": "^11.7.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.12",
    "@types/node": "^22.9.0",
    "@types/react": "18.3.1",
    "@types/react-dom": "18.3.1",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "4.7.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jsdom": "^24.0.0",
    "tailwindcss": "4.1.12",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4",
    "vite": "^6.4.1",
    "vitest": "^4.0.18"
  }
}
